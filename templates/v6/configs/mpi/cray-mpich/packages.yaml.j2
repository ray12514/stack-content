# Rendered for {{ profile.system.name }} / Cray MPICH externals (from mpi_providers)
packages:
  mpi:
    buildable: false
    require:
      - cray-mpich
{% for package in mpi_external_packages(profile, "cray-mpich") %}
  {{ package.name }}:
    buildable: {{ package.buildable | lower }}
{% if package.get("variants") %}
    variants: {{ package.variants }}
{% endif %}
    externals:
{% for external in package.externals %}
      - spec: "{{ external.spec }}"
        prefix: {{ external.prefix }}
{% if external.modules %}
        modules:
{% for module in external.modules %}
          - {{ module }}
{% endfor %}
{% else %}
        modules: []
{% endif %}
{% endfor %}
{% endfor %}
