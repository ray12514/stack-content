{% set matches = (profile.mpi_providers or []) | selectattr("name", "equalto", "cray-mpich") | list %}
{% set mpich = matches[0] if matches else {} %}
# Rendered for {{ profile.system.name }} / Cray MPICH externals (from mpi_providers)
packages:
  mpi:
    buildable: false
    require:
      - cray-mpich
  cray-mpich:
    buildable: false
    variants: +wrappers
    externals:
{% for compiler, flavor in (mpich.get("flavors") or {}) | dictsort %}
      - spec: "cray-mpich@{{ mpich.version }} %{{ compiler }}"
        prefix: {{ flavor.prefix }}
{% set modules = flavor.get("modules") or [] %}
{% if modules %}
        modules:
{% for module in modules %}
          - {{ module }}
{% endfor %}
{% else %}
        modules: []
{% endif %}
{% endfor %}
