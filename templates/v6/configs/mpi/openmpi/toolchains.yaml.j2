# Rendered for {{ profile.system.name }} / OpenMPI toolchains (from mpi_providers)
toolchains:
{% for toolchain in mpi_toolchains(profile, rendered_lanes, "openmpi") %}
  {{ toolchain.name }}:
{% for entry in toolchain.entries %}
    - spec: "{{ entry.spec }}"
      when: "{{ entry.when }}"
{% endfor %}
{% endfor %}
