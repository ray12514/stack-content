# Rendered for {{ profile.system.name }} / site OpenMPI externals (from mpi_providers)
packages:
  all:
    providers:
      mpi:
        - openmpi
  openmpi:
    buildable: false
    externals:
{% for package in mpi_external_packages(profile, "openmpi") %}
{% for external in package.externals %}
      - spec: "{{ external.spec }}"
        prefix: {{ external.prefix }}
{% if external.modules %}
        modules:
{% for module in external.modules %}
          - {{ module }}
{% endfor %}
{% else %}
        modules: []
{% endif %}
{% endfor %}
{% endfor %}
