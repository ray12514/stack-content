# Rendered for {{ profile.system.name }} / site OpenMPI externals (from mpi_providers)
packages:
  all:
    providers:
      mpi:
        - openmpi
  openmpi:
    buildable: false
    externals:
{% for mpi in profile.mpi_providers or [] %}
{% if mpi.name == "openmpi" %}
{% set compiler = mpi.get("compiler") %}
      - spec: "openmpi@{{ mpi.version }}{% if compiler %} %{{ compiler }}{% endif %}"
        prefix: {{ mpi.prefix }}
{% set modules = mpi.get("modules") or [] %}
{% if modules %}
        modules:
{% for module in modules %}
          - {{ module }}
{% endfor %}
{% else %}
        modules: []
{% endif %}
{% endif %}
{% endfor %}
