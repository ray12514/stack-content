# Rendered for {{ profile.system.name }} / {{ stack.name }}
{% set mpi_providers = rendered_lanes | selectattr('mpi_provider') | map(attribute='mpi_provider') | list %}
packages:
  all:
{% if mpi_providers %}
    providers:
      mpi: [{{ mpi_providers[0] }}]
{% endif %}
    prefer:
      - target={{ rendered_lanes[0].target }}
{% set external_policy = stack.get("externals") or {} %}
{% for external in profile.get("system_externals") or [] %}
{% set policy = external_policy.get(external.name) %}
{% if policy and policy not in ["build", "none", "false"] %}
  {{ external.name }}:
    buildable: false
    externals:
      - spec: "{{ external.name }}@{{ external.version }}{% if external.get("variants") %} {{ external.variants }}{% endif %}"
        prefix: {{ external.prefix }}
{% set modules = external.get("modules") or [] %}
{% if modules %}
        modules:
{% for module in modules %}
          - {{ module }}
{% endfor %}
{% else %}
        modules: []
{% endif %}
{% endif %}
{% endfor %}
