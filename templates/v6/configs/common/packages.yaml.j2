# Rendered for {{ profile.system.name }} / {{ stack.name }}
{% set mpi_providers = rendered_lanes | selectattr('mpi_provider') | map(attribute='mpi_provider') | list %}
packages:
  all:
{% if mpi_providers %}
    providers:
      mpi: [{{ mpi_providers[0] }}]
{% endif %}
    prefer:
      - target={{ rendered_lanes[0].target }}
{% for package in common_external_packages(profile, stack) %}
  {{ package.name }}:
    buildable: {{ package.buildable | lower }}
    externals:
{% for external in package.externals %}
      - spec: "{{ external.spec }}"
        prefix: {{ external.prefix }}
{% if external.modules %}
        modules:
{% for module in external.modules %}
          - {{ module }}
{% endfor %}
{% else %}
        modules: []
{% endif %}
{% endfor %}
{% endfor %}
