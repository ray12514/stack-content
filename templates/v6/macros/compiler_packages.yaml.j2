{% macro compiler_packages(target_scope) -%}
# Rendered for {{ profile.system.name }} / compiler externals (from compiler_providers)
packages:
{% for package in compiler_external_packages(profile, stack, target_scope) %}
  {{ package.name }}:
    buildable: {{ package.buildable | lower }}
    externals:
{% for external in package.externals %}
      - spec: "{{ external.spec }}"
        prefix: {{ external.prefix }}
{% if external.modules %}
        modules:
{% for module in external.modules %}
          - {{ module }}
{% endfor %}
{% else %}
        modules: []
{% endif %}
{% if external.get("extra_attributes") %}
        extra_attributes:
          compilers:
            c: {{ external.extra_attributes.compilers.c }}
            cxx: {{ external.extra_attributes.compilers.cxx }}
            fortran: {{ external.extra_attributes.compilers.fortran }}
{% endif %}
{% endfor %}
{% endfor %}
{%- endmacro %}
